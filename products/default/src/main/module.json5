{
  "module": {
    "name": "default",
    "type": "entry",
    "description": "$string:module_desc",
    "routerMap": "$profile:route_map",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "tablet",
      "2in1"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:INTERNET"
      },
      {
        "name": "ohos.permission.CUSTOM_SCREEN_CAPTURE",
        "reason": '$string:app_name',
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.ACCESS_EXTENSIONAL_DEVICE_DRIVER",
        "reason": "$string:ACCESS_EXTENSIONAL_DEVICE_DRIVER"
      },
      {
        "name": "ohos.permission.INPUT_KEYBOARD_CONTROLLER",
        "reason": "$string:INPUT_KEYBOARD_CONTROLLER"
      },
      {
        "name": "ohos.permission.ACCESS_DDK_HID",
        "reason": "$string:ACCESS_DDK_HID"
      },
      //      {
      //        "name": "ohos.permission.MANAGE_PASTEBOARD_APP_SHARE_OPTION",
      //        "reason": "$string:MANAGE_PASTEBOARD_APP_SHARE_OPTION"
      //      },
      {
        "name": "ohos.permission.SYSTEM_FLOAT_WINDOW",
        "reason": "$string:SYSTEM_FLOAT_WINDOW"
      },
      {
        "name": "ohos.permission.READ_MEDIA",
        "reason": "$string:read_media_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.WRITE_MEDIA",
        "reason": "$string:write_media_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.READ_PASTEBOARD",
        "reason": "$string:READ_PASTEBOARD",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        'name': 'ohos.permission.ACCESS_BLUETOOTH',
        "reason": "$string:ACCESS_BLUETOOTH",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      }
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "minWindowHeight": 600,
        "minWindowWidth": 1000,
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:Vector",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
  }
}
