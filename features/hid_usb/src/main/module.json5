{
  "module": {
    "name": "hid_usb",
    "type": "feature",
    "description": "$string:module_desc",
    "mainElement": "Hid_usbAbility",
    "deviceTypes": [
      "tablet",
      "2in1"
    ],
    "requestPermissions": [{"name": 'ohos.permission.ACCESS_DDK_HID'},{"name": 'ohos.permission.ACCESS_EXTENSIONAL_DEVICE_DRIVER'},],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "Hid_usbAbility",
        "srcEntry": "./ets/hid_usbability/Hid_usbAbility.ets",
        "description": "$string:Hid_usbAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:Hid_usbAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
      }
    ]
  }
}