{
  "module": {
    "name": "keymethodconfig",
    "type": "har",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "requestPermissions": [
      {
        'name': 'ohos.permission.INTERNET'
      },
      {
        "name": "ohos.permission.READ_PASTEBOARD",
        "reason": "$string:page_show",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      }
    ]
  }
}
